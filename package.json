{
  "name": "salle-de-sport",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx server/db/migrate.ts",
    "db:seed": "tsx server/db/seed.ts"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "helmet": "^8.2.0",
    "pg": "^8.21.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.6",
    "@tailwindcss/vite": "^4.1.14",
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.0",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-body-highlighter": "^2.0.5",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.1.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  },
  "comment:overrides": "drizzle-kit (devDep, hors prod) tire @esbuild-kit/core-utils qui epingle esbuild 0.18 (avis GHSA-67mh-4wv8-2f99, serveur de dev esbuild). On force esbuild >=0.25 partout pour purger l'audit ; drizzle-kit ne l'utilise qu'en bundler one-shot de sa config.",
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
